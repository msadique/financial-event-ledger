DATABASE_URL=sqlite:///./data/service.db
ACCOUNT_SERVICE_URL=http://localhost:8081
ACCOUNT_SERVICE_TIMEOUT_SECONDS=2
ACCOUNT_SERVICE_MAX_ATTEMPTS=3
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
ASYNC_FALLBACK_ENABLED=true
ASYNC_FALLBACK_POLL_SECONDS=1
ASYNC_FALLBACK_BATCH_SIZE=25
ASYNC_FALLBACK_BASE_BACKOFF_SECONDS=1
ASYNC_FALLBACK_MAX_BACKOFF_SECONDS=60
ASYNC_FALLBACK_JITTER_SECONDS=0.25
LOG_LEVEL=INFO
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORT_TIMEOUT_SECONDS=5
OTEL_SERVICE_VERSION=0.4.0
OTEL_ENVIRONMENT=local
OTEL_EXCLUDED_URLS=health,metrics
